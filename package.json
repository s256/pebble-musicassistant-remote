{
  "name": "pebble-musicassistant-remote",
  "author": "s256",
  "version": "1.0.0",
  "description": "Touch-first Pebble Time 2 remote for Music Assistant.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s256/pebble-musicassistant-remote.git"
  },
  "license": "MIT",
  "keywords": [
    "pebble-app",
    "music-assistant",
    "rebble"
  ],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "Music Assistant",
    "uuid": "1876693b-4f58-4146-acd7-784d6616f870",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "capabilities": [
      "configurable"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "CMD",
