      "ARG_INT",
      "ARG_STR",
      "READY",
      "ST_OK",
      "ST_PLAYER_NAME",
      "ST_TITLE",
      "ST_ARTIST",
      "ST_ALBUM",
      "ST_STATE",
      "ST_VOLUME",
      "ST_MUTED",
      "ST_SHUFFLE",
      "ST_REPEAT",
      "ST_ELAPSED",
      "ST_DURATION",
      "ST_ERROR",
      "PLAYERS_BEGIN",
      "PLAYERS_CHUNK",
      "PLAYERS_END",
      "PLAYER_ROW_ID",
      "PLAYER_ROW_NAME",
      "PLAYER_ROW_STATE",
      "PLAYER_ROW_INDEX",
      "QUICK_BEGIN",
      "QUICK_END",
      "QUICK_ROW_INDEX",
      "QUICK_ROW_LABEL",
      "QUICK_ROW_URI",
      "ARG_TARGET_PLAYER_ID",
      "ARG_PLAYER_IDS",
      "PLAYER_ROW_SYNCED_TO",
      "PLAYER_ROW_GROUP_COUNT",
      "PLAYER_ROW_FLAGS"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "IMAGE_MENU_ICON",
          "file": "icon-25.png",
          "menuIcon": true
        }
      ]
    }
  }
}
